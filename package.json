{
  "name": "t3-sancheck",
  "version": "1.0.0",
  "description": "Lightweight tool for performing statistical sanity checks on ML datasets",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "release": "commit-and-tag-version"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "commit-and-tag-version": "^12.7.3"
  },
  "commit-and-tag-version": {
    "types": [
      {
        "type": "feat",
        "section": "New Feature"
      },
      {
        "type": "fix",
        "section": "Bug Fix"
      },
      {
        "type": "docs",
        "section": "Documentation",
        "hidden": false
      },
      {
        "type": "chore",
        "section": "System Maintenance",
        "hidden": false
      },
      {
        "type": "refactor",
        "section": "Code Refactor",
        "hidden": false
      },
      {
        "type": "perf",
        "section": "Performance Improvement",
        "hidden": false
      }
    ]
  }
}
